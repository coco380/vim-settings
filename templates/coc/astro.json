{
  "languageserver": {
    "astro": {
      "command": "npx",
      "args": [
        "--no-install",
        "astro-ls",
        "--stdio"
      ],
      "filetypes": [
        "astro"
      ],
      "initializationOptions": {
        "typescript": {
          "tsdk": "/absolute/path/to/project/node_modules/typescript/lib"
        }
      },
      "rootPatterns": [
        "package.json"
      ]
    }
  }
}
