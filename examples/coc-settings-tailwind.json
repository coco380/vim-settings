{
  "languageserver": {
    "tailwindCSS": {
      "command": "npx",
      "args": [
        "--no-install",
        "tailwindcss-language-server",
        "--stdio"
      ],
      "filetypes": [
        "astro",
        "html",
        "javascript",
        "javascriptreact",
        "typescript",
        "typescriptreact",
        "css",
        "scss"
      ]
    }
  },
  "tailwindCSS.includeLanguages": {
    "astro": "html",
    "typescriptreact": "javascript",
    "javascriptreact": "javascript",
    "scss": "css"
  },
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "ngClass",
    "class:list"
  ],
  "tailwindCSS.classFunctions": [
    "cva",
    "cx",
    "cn"
  ]
}
